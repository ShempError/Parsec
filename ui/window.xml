<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/">

    <!-- Main Parsec Window -->
    <Frame name="ParsecWindow" parent="UIParent" toplevel="true" movable="true" resizable="true" enableMouse="true" hidden="true">
        <Size>
            <AbsDimension x="220" y="200"/>
        </Size>
        <Anchors>
            <Anchor point="CENTER"/>
        </Anchors>

        <Backdrop bgFile="Interface\Tooltips\UI-Tooltip-Background" edgeFile="Interface\Tooltips\UI-Tooltip-Border" tile="true">
            <BackgroundInsets>
                <AbsInset left="4" right="4" top="4" bottom="4"/>
            </BackgroundInsets>
            <TileSize>
                <AbsValue val="16"/>
            </TileSize>
            <EdgeSize>
                <AbsValue val="16"/>
            </EdgeSize>
        </Backdrop>

        <Layers>
            <!-- Title Bar Background -->
            <Layer level="BACKGROUND">
                <Texture name="ParsecWindowTitleBG">
                    <Size>
                        <AbsDimension x="212" y="20"/>
                    </Size>
                    <Anchors>
                        <Anchor point="TOPLEFT">
                            <Offset>
                                <AbsDimension x="4" y="-4"/>
                            </Offset>
                        </Anchor>
                    </Anchors>
                    <Color r="0.1" g="0.1" b="0.1" a="0.8"/>
                </Texture>
            </Layer>

            <Layer level="OVERLAY">
                <!-- Title Text -->
                <FontString name="ParsecWindowTitle" inherits="GameFontNormalSmall" text="Parsec - Damage">
                    <Anchors>
                        <Anchor point="TOPLEFT">
                            <Offset>
                                <AbsDimension x="8" y="-7"/>
                            </Offset>
                        </Anchor>
                    </Anchors>
                    <Color r="0" g="0.8" b="1"/>
                </FontString>

                <!-- Segment Label -->
                <FontString name="ParsecWindowSegment" inherits="GameFontNormalSmall" text="Current">
                    <Anchors>
                        <Anchor point="TOPRIGHT">
                            <Offset>
                                <AbsDimension x="-24" y="-7"/>
                            </Offset>
                        </Anchor>
                    </Anchors>
                    <Color r="0.7" g="0.7" b="0.7"/>
                </FontString>
            </Layer>
        </Layers>

        <Frames>
            <!-- Close Button -->
            <Button name="ParsecWindowClose" inherits="UIPanelCloseButton">
                <Size>
                    <AbsDimension x="20" y="20"/>
                </Size>
                <Anchors>
                    <Anchor point="TOPRIGHT">
                        <Offset>
                            <AbsDimension x="-2" y="-2"/>
                        </Offset>
                    </Anchor>
                </Anchors>
                <Scripts>
                    <OnClick>ParsecWindow:Hide()</OnClick>
                </Scripts>
            </Button>

            <!-- Resize Handle -->
            <Frame name="ParsecWindowResizeHandle" enableMouse="true">
                <Size>
                    <AbsDimension x="16" y="16"/>
                </Size>
                <Anchors>
                    <Anchor point="BOTTOMRIGHT"/>
                </Anchors>
                <Layers>
                    <Layer level="OVERLAY">
                        <Texture name="ParsecWindowResizeTex" file="Interface\AddOns\Parsec\textures\ResizeGrip">
                            <Size>
                                <AbsDimension x="16" y="16"/>
                            </Size>
                            <Anchors>
                                <Anchor point="BOTTOMRIGHT"/>
                            </Anchors>
                        </Texture>
                    </Layer>
                </Layers>
                <Scripts>
                    <OnMouseDown>ParsecWindow:StartSizing("BOTTOMRIGHT")</OnMouseDown>
                    <OnMouseUp>
                        ParsecWindow:StopMovingOrSizing()
                        if Parsec and Parsec.OnWindowResize then
                            Parsec.OnWindowResize()
                        end
                    </OnMouseUp>
                </Scripts>
            </Frame>

            <!-- Scrollable bar container -->
            <Frame name="ParsecBarContainer">
                <Size>
                    <AbsDimension x="212" y="168"/>
                </Size>
                <Anchors>
                    <Anchor point="TOPLEFT">
                        <Offset>
                            <AbsDimension x="4" y="-24"/>
                        </Offset>
                    </Anchor>
                </Anchors>
            </Frame>
        </Frames>

        <Scripts>
            <OnMouseDown>
                if arg1 == "LeftButton" then
                    this:StartMoving()
                end
            </OnMouseDown>
            <OnMouseUp>
                this:StopMovingOrSizing()
            </OnMouseUp>
            <OnDragStop>
                this:StopMovingOrSizing()
            </OnDragStop>
            <OnSizeChanged>
                if Parsec and Parsec.OnWindowResize then
                    Parsec.OnWindowResize()
                end
            </OnSizeChanged>
        </Scripts>
    </Frame>

</Ui>
